# App
APP_NAME=DesktopHab
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-this
DEBUG=True

# Database (async + sync URLs)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/desktophab
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/desktophab

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe (leave empty for now if not testing payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SMARTCALENDER_PRICE_ID=

# Admin panel
ADMIN_SECRET_KEY=your-admin-secret-key
FIRST_ADMIN_EMAIL=admin@desktophab.com
FIRST_ADMIN_PASSWORD=changeme

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# URLs
SITE_URL=http://localhost:8000
RENEWAL_BASE_URL=http://localhost:8000/renew-smartcalender
